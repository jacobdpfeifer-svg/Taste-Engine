# Embedding backend: "stub" (deterministic, no downloads) or "openclip"
EMBEDDING_BACKEND=stub
EMBEDDING_DIM=64
# openclip settings (only used if EMBEDDING_BACKEND=openclip)
OPENCLIP_MODEL=ViT-B-32
OPENCLIP_PRETRAINED=laion2b_s34b_b79k
# sqlite path
DB_PATH=taste.sqlite3
# stimulus bank (defaults to data/stimuli.json if present, else data/stimuli.sample.json)
#STIMULI_PATH=data/stimuli.json
# where fitted taste kernels are written (gitignored)
KERNELS_DIR=kernels
